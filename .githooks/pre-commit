#!/bin/sh
set -e

# Gofmt check (same as CI)
echo "pre-commit: gofmt"
out=$(git ls-files '*.go' | xargs gofmt -l)
if [ -n "$out" ]; then
    echo "Unformatted Go files:"
    echo "$out"
    echo "Run: go fmt ./..."
    exit 1
fi

# golangci-lint (config verify + run, same as CI action)
if command -v golangci-lint >/dev/null 2>&1; then
    echo "pre-commit: golangci-lint config verify"
    golangci-lint config verify
    echo "pre-commit: golangci-lint run"
    golangci-lint run ./...
else
    echo "pre-commit: go vet (install golangci-lint for full checks)"
    go vet ./...
fi

# Tests with race detector (same as CI)
echo "pre-commit: go test -race"
go test -race ./...

# Vet and build (same as CI)
echo "pre-commit: go vet"
go vet ./...
echo "pre-commit: go build"
go build ./cmd/frisco

# Vulnerability scan (same as CI)
if command -v govulncheck >/dev/null 2>&1; then
    echo "pre-commit: govulncheck"
    govulncheck ./...
else
    echo "pre-commit: govulncheck skipped (install: go install golang.org/x/vuln/cmd/govulncheck@latest)"
fi

echo "pre-commit: ok"
