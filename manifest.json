{
  "manifest_version": "0.3",
  "name": "martmart",
  "display_name": "MartMart CLI",
  "version": "0.0.0",
  "description": "MartMart CLI — shared grocery delivery CLI for Frisco.pl and Delio.",
  "author": {
    "name": "Rafał Rudol"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wydrox/martmart-cli.git"
  },
  "license": "MIT",
  "server": {
    "type": "binary",
    "entry_point": "server/martmart",
    "mcp_config": {
      "command": "${__dirname}/server/martmart",
      "args": ["mcp"],
      "platform_overrides": {
        "win32": {
          "command": "${__dirname}/server/martmart.exe",
          "args": ["mcp"]
        }
      }
    }
  },
  "tools_generated": true,
  "compatibility": {
    "platforms": ["darwin", "win32", "linux"]
  }
}
